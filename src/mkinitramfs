#!/bin/bash

usage() {
  cat <<EOF
Uso: $0 [opciones]
Opciones:
  -k, --kernel VER      Versión del kernel (por defecto: \$(uname -r))
  -r, --release STR     Sufijo de release (por defecto: empty)
  -c, --compress FORMAT Compresión: gz, xz, zstd (por defecto: zstd)
  -p, --profile PROFILE Perfil: disk, live, netinstall (por defecto: disk)
  -o, --output FILE     Ruta de salida (por defecto: /boot/initrd-*)
  --tools-dir DIR       Directorio con binarios estáticos (live/netinstall)
  --staging DIR         Directorio de trabajo temporal
  --neonatox-dir DIR    Ruta a neonatox-live-boot (lib/ + libexec/)
  --hooks-dir DIR       Directorio adicional de hooks (proyecto)
  --xz-extreme          Usar compresión xz --extreme
  -h, --help            Muestra esta ayuda
EOF
  exit 0
}

KERNEL_VERSION=$(uname -r)
RELEASE=""
ARCH=$(uname -m)
COMPRESS="zstd"
PROFILE="disk"
CUSTOM_OUTPUT=""
TOOLS_DIR=""
CUSTOM_STAGING=""
NEONATOX_DIR=""
CUSTOM_HOOKDIR=""
XZ_EXTREME=false
USE_BUSYBOX=false

while [[ $# -gt 0 ]]; do
  case $1 in
    -k|--kernel)
      KERNEL_VERSION="$2"; shift 2 ;;
    -r|--release)
      RELEASE="$2"; shift 2 ;;
    -c|--compress)
      COMPRESS="$2"; shift 2 ;;
    -p|--profile)
      PROFILE="$2"; shift 2 ;;
    -o|--output)
      CUSTOM_OUTPUT="$2"; shift 2 ;;
    --tools-dir)
      TOOLS_DIR="$2"; shift 2 ;;
    --staging)
      CUSTOM_STAGING="$2"; shift 2 ;;
    --neonatox-dir)
      NEONATOX_DIR="$2"; shift 2 ;;
    --hooks-dir)
      CUSTOM_HOOKDIR="$2"; shift 2 ;;
    --xz-extreme)
      XZ_EXTREME=true; shift ;;
    -h|--help)
      usage ;;
    *)
      echo "Opción desconocida: $1"
      usage
      exit 1 ;;
  esac
done

case "$PROFILE" in
  disk|live|netinstall) ;;
  *) echo "Error: perfil '$PROFILE' no válido (disk, live, netinstall)"; exit 1 ;;
esac

if [ -n "$KERNEL_VERSION" ] && [ ! -d "/usr/lib/modules/$KERNEL_VERSION" ]; then
  echo "Error: No existe /usr/lib/modules/$KERNEL_VERSION"
  exit 1
fi

case "$COMPRESS" in
  gz|xz|zstd) ;;
  *) echo "Error: compresión '$COMPRESS' no soportada. Use: gz, xz, zstd"; exit 1 ;;
esac

if [ "$PROFILE" != "disk" ]; then
  if [ -z "$NEONATOX_DIR" ]; then
    for d in /usr/share/neonatox-boot /usr/local/share/neonatox-boot; do
      [ -d "$d" ] && { NEONATOX_DIR="$d"; break; }
    done
  fi
  if [ -z "$NEONATOX_DIR" ] || [ ! -f "$NEONATOX_DIR/init" ]; then
    echo "Error: --neonatox-dir requerido para perfil '$PROFILE' (no se encontró init)"
    exit 1
  fi
fi

INITRAMFS_FILE="${CUSTOM_OUTPUT:-/boot/initrd-${KERNEL_VERSION}-${ARCH}${RELEASE:+-${RELEASE}}}"

DATADIR=/usr/share/mkinitramfs
INITIN=init.in
HOOKDIR=/usr/share/mkinitramfs/hooks

if [ -f /etc/mkinitramfs.conf ]; then
  . /etc/mkinitramfs.conf
fi

: "${COMPRESSION:=zstd}"
: "${SPLASH:=none}"

if [ -n "$CUSTOM_STAGING" ]; then
  WDIR="$CUSTOM_STAGING"
  rm -rf "$WDIR"
  mkdir -p "$WDIR"
else
  WDIR=$(mktemp -d /tmp/initrd-work.XXXXXXXXXX)
fi
unsorted=$(mktemp /tmp/unsorted.XXXXXXXXXX)

run_hooks() {
  local phase="$1"
  for dir in "$HOOKDIR/$phase" ${CUSTOM_HOOKDIR:+"$CUSTOM_HOOKDIR/$phase"}; do
    [ -d "$dir" ] || continue
    for hook in "$dir"/*; do
      [ -x "$hook" ] || continue
      TOOLS_DIR="$TOOLS_DIR" NEONATOX_DIR="$NEONATOX_DIR" PROFILE="$PROFILE" \
        "$hook" "$WDIR" || { echo "Hook $hook falló"; return 1; }
    done
  done
}

# ----------------------------------------------------------
# ESTRUCTURA BÁSICA
# ----------------------------------------------------------
mkdir -p $WDIR/{dev,run,sys,proc,usr/{bin,lib/{firmware,modules},sbin}}
mkdir -p $WDIR/etc/{modprobe.d,udev/rules.d}
touch $WDIR/etc/modprobe.d/modprobe.conf
ln -s usr/bin  $WDIR/bin
ln -s usr/lib  $WDIR/lib
ln -s usr/sbin $WDIR/sbin
ln -s lib      $WDIR/lib64

mknod -m 640 $WDIR/dev/console c 5 1
mknod -m 664 $WDIR/dev/null    c 1 3

if [ -d /etc/modprobe.d ]; then
  cp -a /etc/modprobe.d/* $WDIR/etc/modprobe.d 2>/dev/null || true
fi

if [ -f /etc/udev/udev.conf ]; then
  cp /etc/udev/udev.conf $WDIR/etc/udev/udev.conf
fi
for file in $(find /etc/udev/rules.d/ -type f 2>/dev/null); do
  cp "$file" $WDIR/etc/udev/rules.d 2>/dev/null || true
done

# LVM config (solo perfil disk)
if [ "$PROFILE" = "disk" ] && [ -x /usr/sbin/lvm ]; then
  cp -a /etc/lvm $WDIR/etc 2>/dev/null || true
fi

# ----------------------------------------------------------
# INIT + LIBRARIES
# ----------------------------------------------------------
if [ "$PROFILE" = "disk" ]; then
  install -m0755 "$DATADIR/$INITIN" "$WDIR/init"
else
  install -m0755 "$NEONATOX_DIR/init" "$WDIR/init"
  cp -r "$NEONATOX_DIR/lib" "$WDIR/usr/"
  cp -r "$NEONATOX_DIR/libexec" "$WDIR/"
  chmod 0755 "$WDIR/libexec"/* 2>/dev/null || true
fi

run_hooks pre-binaries

# ----------------------------------------------------------
# BINARIOS POR PERFIL
# ----------------------------------------------------------
case "$PROFILE" in
  disk)
    binfiles="sh cat cp dd killall ls mkdir mknod mount umount sed sleep ln rm uname readlink basename"
    [ -x /usr/bin/udevadm ] && binfiles="$binfiles udevadm"

    sbinfiles="modprobe blkid switch_root"
    for f in mdadm mdmon udevd udevadm; do
      [ -x /usr/sbin/$f ] && sbinfiles="$sbinfiles $f"
    done
    [ -x /usr/sbin/lvm ] && sbinfiles="$sbinfiles lvm dmsetup"
    ;;
  live|netinstall)
    binfiles="sh cat cp dd ls mkdir mount umount sed sleep ln rm uname readlink basename"
    sbinfiles="modprobe switch_root"
    # mdev en lugar de udevd
    ;;
esac

copy() {
  local file
  if [ "$2" = "lib" ]; then
    file=$(PATH=/usr/lib type -p "$1")
  else
    file=$(type -p "$1")
  fi
  if [ -n "$file" ]; then
    cp "$file" "$WDIR/usr/$2"
  else
    echo "Error: no se encontró $1 para copiar a /usr/$2"
    rm -rf "$WDIR"
    exit 1
  fi
}

# Busybox + applet symlinks (live/netinstall con --tools-dir)
# MUST come before ldd blocks so USE_BUSYBOX=true skips ldd entirely
if [ "$PROFILE" != "disk" ] && [ -n "$TOOLS_DIR" ] && [ -f "$TOOLS_DIR/busybox" ]; then
  USE_BUSYBOX=true
  install -m0755 "$TOOLS_DIR/busybox" "$WDIR/usr/bin/busybox"
  ( cd "$WDIR/usr/bin" && ./busybox --list 2>/dev/null | \
    grep -v "^init$" | grep -v "^poweroff$" | grep -v "^reboot$" | \
    while read -r app; do
      [ "$app" = "busybox" ] && continue
      ln -sf busybox "$app"
    done
  )
  # Si bash está presente en PROFILE_REQUIRES, usarlo como sh
  [ -x "$WDIR/usr/bin/bash" ] && ln -sf bash "$WDIR/usr/bin/sh"
fi

# PROFILE_REQUIRES: tools estáticas (live/netinstall)
if [ "$PROFILE" != "disk" ]; then
  case "$PROFILE" in
    netinstall) PROFILE_LIB="$NEONATOX_DIR/lib/init-net.sh" ;;
    *)          PROFILE_LIB="$NEONATOX_DIR/lib/init-${PROFILE}.sh" ;;
  esac
  if [ -f "$PROFILE_LIB" ]; then
    REQUIRES=$(grep '^PROFILE_REQUIRES=' "$PROFILE_LIB" | cut -d'"' -f2)
    for tool in $REQUIRES; do
      if [ -n "$TOOLS_DIR" ] && [ -f "$TOOLS_DIR/$tool" ]; then
        install -m0755 "$TOOLS_DIR/$tool" "$WDIR/usr/bin/$tool"
      fi
    done
  fi
fi

# ldd en musl es un wrapper (exec /lib/libc.so --list $@) que puede colgarse
# con binarios glibc o estáticos. Cuando USE_BUSYBOX=true se salta todo esto.
if [ "$USE_BUSYBOX" = false ]; then
for f in $binfiles; do
  [ -x "/usr/bin/$f" ] || continue
  ldd "/usr/bin/$f" | sed 's/\t//' | cut -d' ' -f1 >> "$unsorted"
  copy "/usr/bin/$f" bin
done

for f in $sbinfiles; do
  cmd=$(type -p "$f")
  [ -n "$cmd" ] || continue
  ldd "$cmd" | sed 's/\t//' | cut -d' ' -f1 >> "$unsorted"
  copy "$cmd" sbin
done
fi

if [ "$USE_BUSYBOX" = false ]; then
# Binarios de udev/systemd (solo perfil disk)
if [ "$PROFILE" = "disk" ]; then
  if [ -x /usr/lib/udev/udevd ]; then
    ldd /usr/lib/udev/udevd | sed 's/\t//' | cut -d' ' -f1 >> "$unsorted"
  elif [ -x /usr/lib/systemd/systemd-udevd ]; then
    ldd /usr/lib/systemd/systemd-udevd | sed 's/\t//' | cut -d' ' -f1 >> "$unsorted"
  fi
fi
fi

if [ "$USE_BUSYBOX" = false ]; then
# Symlinks kmod (solo cuando no usamos busybox, que ya los provee)
if [ -n "$KERNEL_VERSION" ] && [ -x /usr/bin/kmod ]; then
  binfiles="$binfiles kmod"
  ln -sf kmod $WDIR/usr/bin/lsmod
  ln -sf kmod $WDIR/usr/bin/insmod
else
  binfiles="$binfiles lsmod"
  sbinfiles="$sbinfiles insmod"
fi

# Symlinks LVM (solo perfil disk)
if [ "$PROFILE" = "disk" ] && [ -x /usr/sbin/lvm ]; then
  for cmd in lvchange lvrename lvextend lvcreate lvdisplay lvscan \
             pvchange pvck pvcreate pvdisplay pvscan \
             vgchange vgcreate vgrename vgscan vgck; do
    ln -sf lvm $WDIR/usr/sbin/$cmd
  done
fi

# Bibliotecas únicas
sort "$unsorted" | uniq | while read lib; do
  case "$lib" in
    ""|linux-vdso.so.1|linux-gate.so.1|libsystemd-shared*) continue ;;
  esac
  copy "$lib" lib
done
fi

# udev/systemd (solo perfil disk)
if [ "$PROFILE" = "disk" ]; then
  [ -d /usr/lib/udev ]   && cp -a /usr/lib/udev   $WDIR/usr/lib
  [ -d /usr/lib/systemd ] && cp -a /usr/lib/systemd $WDIR/usr/lib
  [ -d /usr/lib/elogind ] && cp -a /usr/lib/elogind $WDIR/usr/lib
fi

# Configuración RAID (solo perfil disk)
if [ "$PROFILE" = "disk" ] && [ -f /etc/mdadm.conf ]; then
  cp /etc/mdadm.conf $WDIR/etc
fi

# ----------------------------------------------------------
# MÓDULOS DEL KERNEL POR PERFIL
# ----------------------------------------------------------
if [ -n "$KERNEL_VERSION" ]; then
  case "$PROFILE" in
    disk)
      find \
        /usr/lib/modules/$KERNEL_VERSION/kernel/{crypto,fs,lib} \
        /usr/lib/modules/$KERNEL_VERSION/kernel/drivers/{block,ata,nvme,md,firewire} \
        /usr/lib/modules/$KERNEL_VERSION/kernel/drivers/{scsi,message,pcmcia,virtio} \
        /usr/lib/modules/$KERNEL_VERSION/kernel/drivers/usb/{host,storage} \
        -type f 2>/dev/null | cpio -p --make-directories --quiet "$WDIR"
      ;;
    live)
      find \
        /usr/lib/modules/$KERNEL_VERSION/kernel/fs \
        /usr/lib/modules/$KERNEL_VERSION/kernel/lib \
        /usr/lib/modules/$KERNEL_VERSION/kernel/drivers/{block,ata,nvme} \
        /usr/lib/modules/$KERNEL_VERSION/kernel/drivers/{scsi,virtio} \
        /usr/lib/modules/$KERNEL_VERSION/kernel/drivers/usb/{host,storage} \
        /usr/lib/modules/$KERNEL_VERSION/kernel/drivers/{hid,cdrom,input} \
        -type f 2>/dev/null | cpio -p --make-directories --quiet "$WDIR"
      ;;
    netinstall)
      find \
        /usr/lib/modules/$KERNEL_VERSION/kernel/fs \
        /usr/lib/modules/$KERNEL_VERSION/kernel/lib \
        /usr/lib/modules/$KERNEL_VERSION/kernel/drivers/{block,ata,nvme} \
        /usr/lib/modules/$KERNEL_VERSION/kernel/drivers/{scsi,virtio} \
        /usr/lib/modules/$KERNEL_VERSION/kernel/drivers/usb/{host,storage} \
        /usr/lib/modules/$KERNEL_VERSION/kernel/drivers/net \
        -type f 2>/dev/null | cpio -p --make-directories --quiet "$WDIR"
      ;;
  esac

  mkdir -p "$WDIR/usr/lib/modules/$KERNEL_VERSION"
  cp /usr/lib/modules/$KERNEL_VERSION/modules.{builtin,order} "$WDIR/usr/lib/modules/$KERNEL_VERSION"/
  [ -f /usr/lib/modules/$KERNEL_VERSION/modules.builtin.modinfo ] && \
    cp /usr/lib/modules/$KERNEL_VERSION/modules.builtin.modinfo "$WDIR/usr/lib/modules/$KERNEL_VERSION"/

  # Firmware mínimo
  mkdir -p "$WDIR/usr/lib/firmware"
  find "$WDIR/usr/lib/modules/$KERNEL_VERSION" -name "*.ko*" \
  | xargs -r modinfo -F firmware \
  | sort -u \
  | while read -r fw; do
      [ -n "$fw" ] || continue
      if [ -f "/usr/lib/firmware/$fw" ]; then
        install -D "/usr/lib/firmware/$fw" "$WDIR/usr/lib/firmware/$fw"
      elif [ -f "/usr/lib/firmware/$fw.zst" ]; then
        install -D "/usr/lib/firmware/$fw.zst" "$WDIR/usr/lib/firmware/$fw.zst"
      elif [ -f "/usr/lib/firmware/$fw.xz" ]; then
        install -D "/usr/lib/firmware/$fw.xz" "$WDIR/usr/lib/firmware/$fw.xz"
      fi
    done

  # Descomprimir módulos del kernel (compatibilidad con kernels sin módulo decompress)
  find "$WDIR/usr/lib/modules" -name "*.ko.zst" -exec unzstd -f --rm {} \; 2>/dev/null || true
  find "$WDIR/usr/lib/modules" -name "*.ko.gz" -exec gunzip -f {} \; 2>/dev/null || true
  find "$WDIR/usr/lib/modules" -name "*.ko.xz" -exec unxz -f {} \; 2>/dev/null || true

  # Intentar depmod; si falla (0 bytes), copiar del host y parchear rutas
  depmod -b "$WDIR" "$KERNEL_VERSION" 2>/dev/null || true
  if [ ! -s "$WDIR/usr/lib/modules/$KERNEL_VERSION/modules.dep" ]; then
    echo "depmod produced empty modules.dep, copying from host..." >&2
    for f in modules.dep modules.alias modules.symbols modules.softdep modules.devname; do
      if [ -f "/usr/lib/modules/$KERNEL_VERSION/$f" ]; then
        cp "/usr/lib/modules/$KERNEL_VERSION/$f" "$WDIR/usr/lib/modules/$KERNEL_VERSION/"
      fi
    done
    sed -i 's/\.ko\.zst/.ko/g' "$WDIR/usr/lib/modules/$KERNEL_VERSION/modules.dep" 2>/dev/null || true
    sed -i 's/\.ko\.zst/.ko/g' "$WDIR/usr/lib/modules/$KERNEL_VERSION/modules.alias" 2>/dev/null || true
  fi
fi

run_hooks pre-pack

# ----------------------------------------------------------
# EMPAQUETADO
# ----------------------------------------------------------
compress() {
  case "$COMPRESS" in
    gz)  gzip -n -f ;;
    xz)  xz -9 -c --check=crc32 ${XZ_EXTREME:+--extreme} ;;
    zstd) zstd -T0 -19 -c ;;
  esac
}

printf "Creando $INITRAMFS_FILE... "
( cd "$WDIR" && find . | cpio -o -H newc --quiet ) | compress > "${INITRAMFS_FILE}.tmp" -

run_hooks pre-microcode

# Microcódigo
if ls /usr/lib/firmware/intel-ucode/* >/dev/null 2>&1 || \
   ls /usr/lib/firmware/amd-ucode/*   >/dev/null 2>&1; then
  rm -rf "$WDIR"/*
  DSTDIR=$WDIR/kernel/x86/microcode
  mkdir -p "$DSTDIR"
  [ -d /usr/lib/firmware/amd-ucode ] && \
    cat /usr/lib/firmware/amd-ucode/microcode_amd*.bin > "$DSTDIR/AuthenticAMD.bin"
  [ -d /usr/lib/firmware/intel-ucode ] && \
    cat /usr/lib/firmware/intel-ucode/* > "$DSTDIR/GenuineIntel.bin"
  ( cd "$WDIR"; find . | cpio -o -H newc --quiet ) | cat - "${INITRAMFS_FILE}.tmp" > "$INITRAMFS_FILE"
else
  mv "${INITRAMFS_FILE}.tmp" "$INITRAMFS_FILE"
fi

if [ -z "$CUSTOM_STAGING" ]; then
  rm -rf "$WDIR"
fi
rm -f "$unsorted"

printf "listo.\n"
